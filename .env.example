# ─────────────────────────────────────────────────────────────
#  Aternos Discord Bot — Environment Variables
#
#  Pterodactyl Panel:  Add these in the "Variables" tab of
#                      your server, then restart the server.
#
#  Local / other host: Copy this file to ".env" and fill in
#                      your values.
# ─────────────────────────────────────────────────────────────

# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# Your Aternos account username
ATERNOS_USER=your_aternos_username

# Your Aternos account password
ATERNOS_PASS=your_aternos_password
